                "name": "groupId",
                "value": "",
                "type": "query",
                "description": "Filter assessments by impacted group identifier"
              }
            ]
          },
          "docs": "Retrieves ADKAR assessments for a specific project. ADKAR stands for Awareness, Desire, Knowledge, Ability, and Reinforcement."
        },
        {
          "info": {
            "name": "Prosci Create an ADKAR assessment",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.prosci.com/v1/projects/:projectId/adkar-assessments",
