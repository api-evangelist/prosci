              {
                "name": "limit",
                "value": "",
                "type": "query",
                "description": "Maximum number of items to return"
              },
              {
                "name": "offset",
                "value": "",
                "type": "query",
                "description": "Number of items to skip for pagination"
              },
              {
                "name": "stakeholderId",
                "value": "",
                "type": "query",
                "description": "Filter assessments by stakeholder identifier"
              },
